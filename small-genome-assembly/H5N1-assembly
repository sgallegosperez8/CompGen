# Small Genome Assembly - Using velvetg and velveth 

#Working from the directory where you would like to place the SRA for the genome 
wget https://sra-pub-run-odp.s3.amazonaws.com/sra/SRR37057348/SRR37057348

#Convert to fastQ through SRA toolkit
fastq-dump -I --split-files SRR37057348
#will produce SRA_2.fastq and SRA_2.fastq(forward and reverse)

#assess quality reads
fastqc SRR37057348_1.fastq SRR37057348_2.fastq

#produce _1/_2:(2).fastqc.html (2)fastqc.zip
#generates reports which should be stored as html


#Used Trimmomatic to cut sequences < PHREDQUALITY=30
java -jar $HOME/tools/Trimmomatic-0.39/trimmomatic-0.39.jar PE -threads 6 SRR37057348_1.fastq SRR37057348_2.fastq SRR37057348_1_trimmed.fastq SRR37057348un_1.fastq SRR37057348_2_trimmed.fastq SRR37057348un_2.fastq TRAILING:30

#now running velveth(hashing table) and velvetg
time velveth debruijn_kmer25 25 -shortPaired -fastq -separate SRR37057348_1_trimmed.fastq SRR37057348_2_trimmed.fastq

#velveth --help (explains how the line should look)
#time gives how long the process took, velveth is the program, debruijn_kmer25 is the name of the directory created with its assoc. files[roadmaps,sequences]

